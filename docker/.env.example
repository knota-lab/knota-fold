# Copy this file to .env.staging or .env.production and replace placeholder values.

# --------------------------------------------------
# Data (persistent volumes)
# --------------------------------------------------
# Host directory for persistent service data. Relative to the docker/ directory.
# Creates subdirectories: pg/ redis/ minio/ qdrant/ easytier/ logs/
DATA_DIR=../data/docker

# --------------------------------------------------
# Caddy (reverse proxy)
# --------------------------------------------------
# Public domain name (e.g. admin.example.com).
# Leave empty for staging/internal — Caddyfile uses http:// prefix to disable
# automatic HTTPS. When deploying with a real domain, remove the http:// prefix
# from Caddyfile and set this to the domain name.
DOMAIN=
# HTTP/HTTPS ports on the host. Default: 80 / 443.
# CADDY_PORT=80
# CADDY_HTTPS_PORT=443

# --------------------------------------------------
# Server
# --------------------------------------------------
LOCO_ENV=production
PORT=5150
# Publicly reachable URL of the backend (used for generated links, e.g. email).
# In Docker: point to the Caddy URL, e.g. https://admin.example.com
APP_HOST=http://localhost:5150
RUST_LOG=info

# --------------------------------------------------
# Database
# --------------------------------------------------
DATABASE_URL=postgres://knota:change-me@db_postgres:5432/knota_fold
DB_CONNECT_TIMEOUT=5000
DB_IDLE_TIMEOUT=5000
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=10

# --------------------------------------------------
# PostgreSQL container bootstrap
# --------------------------------------------------
POSTGRES_DB=knota_fold
POSTGRES_USER=knota
POSTGRES_PASSWORD=change-me

# --------------------------------------------------
# Redis
# --------------------------------------------------
REDIS_URL=redis://redis:6379/0
# Required for production (Redis healthcheck + requirepass).
# For staging, Redis runs without password — leave empty or unset.
REDIS_PASSWORD=change-me

# --------------------------------------------------
# Queue
# --------------------------------------------------
QUEUE_NUM_WORKERS=2

# --------------------------------------------------
# Auth
# --------------------------------------------------
# JWT_SECRET must be a valid Base64-encoded string (loco-rs uses HS512).
# Generate one: openssl rand -base64 32
JWT_SECRET=replace-with-a-base64-encoded-secret

# --------------------------------------------------
# S3 / MinIO
# --------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=knota-fold-staging
S3_TEST_BUCKET=knota-fold-test
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --------------------------------------------------
# Captcha
# --------------------------------------------------
CAPTCHA_SECRET_KEY=replace-with-captcha-secret
CAPTCHA_TTL_SECONDS=300
CAPTCHA_LENGTH=5
CAPTCHA_WIDTH=130
CAPTCHA_HEIGHT=40
CAPTCHA_COMPLEXITY=3
CAPTCHA_DARK_MODE=false

# --------------------------------------------------
# App Logs
# --------------------------------------------------
APP_LOGS_CAPTURE_LEVEL=warn

# --------------------------------------------------
# Scheduler
# --------------------------------------------------
SCHEDULER_MAX_CONCURRENT=3
SCHEDULER_LOG_RETENTION_DAYS=90
SCHEDULER_OUTPUT_MAX_BYTES=65536

# --------------------------------------------------
# EasyTier (optional)
# --------------------------------------------------
# Required only when running the EasyTier sidecar/profile.
# Use at least 16 characters; generate a random secret for real environments.
EASYTIER_SECRET=
EASYTIER_NETWORK_NAME=

# --------------------------------------------------
# Knowledge Base (optional — requires Qdrant + LLM infra)
# --------------------------------------------------
# ⚠ production.yaml currently lacks the knowledgeBase config section.
# Until that is added, these variables are only effective in dev/test.

# ── Vector Database ──────────────────────────────────────────────
QDRANT_URL=http://qdrant:6334

# ── Embedding Model ──────────────────────────────────────────────
# Provider: openai-compatible API. Default: Ollama bge-m3.
EMBEDDING_API_KEY=ollama
EMBEDDING_BASE_URL=http://localhost:11434/v1

# ── QA LLM ───────────────────────────────────────────────────────
# To switch from local Ollama to a cloud provider, uncomment and fill:
#
# QA_LLM_PROVIDER=deepseek
# QA_LLM_MODEL=deepseek-v4-pro
# QA_LLM_BASE_URL=https://api.deepseek.com
# QA_LLM_API_KEY=sk-your-deepseek-key
#
# Default (Ollama):
QA_LLM_PROVIDER=ollama
QA_LLM_MODEL=qwen3.5:9b
QA_LLM_BASE_URL=http://localhost:11434/v1
QA_LLM_API_KEY=ollama
