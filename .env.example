# ── Auth ────────────────────────────────────────────────────────
# JWT_SECRET must be valid Base64 (loco-rs uses HS512).
# Generate: openssl rand -base64 32
# JWT_SECRET=change-me-dev-jwt-secret-base64

# Stateless CAPTCHA signing key.
# CAPTCHA_SECRET_KEY=change-me-dev-captcha-secret

# ── Database ─────────────────────────────────────────────────────
# Default: SQLite (data/knota-fold_development.sqlite)
# DATABASE_URL=postgres://knota:knota_dev_password@localhost:5432/knota_fold

# ── Redis (optional, default: InMem cache) ──────────────────────
# REDIS_URL=redis://localhost:6379

# ── S3 / MinIO ───────────────────────────────────────────────────
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=knota-fold-dev
# S3_FORCE_PATH_STYLE=true

# ── Embedding (Ollama bge-m3) ──────────────────────────────────
# EMBEDDING_API_KEY=ollama
# EMBEDDING_BASE_URL=http://localhost:11434/v1

# ── Knowledge Base QA LLM ──────────────────────────────────────
# Uncomment and fill to switch from Ollama to a cloud provider:
#
# QA_LLM_PROVIDER=deepseek
# QA_LLM_MODEL=deepseek-v4-pro
# QA_LLM_BASE_URL=https://api.deepseek.com
# QA_LLM_API_KEY=sk-your-deepseek-key
#
# Default (Ollama):
# QA_LLM_PROVIDER=ollama
# QA_LLM_MODEL=qwen3.5:9b
# QA_LLM_BASE_URL=http://localhost:11434/v1
# QA_LLM_API_KEY=ollama

# ── Qdrant ───────────────────────────────────────────────────────
# QDRANT_URL=http://localhost:6334
